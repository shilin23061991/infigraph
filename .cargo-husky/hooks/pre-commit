#!/bin/sh
set -e

echo '+cargo fmt -- --check'
cargo fmt -- --check

echo '+cargo clippy --all-targets -- -D warnings'
cargo clippy --all-targets -- -D warnings

echo '+cargo test -p infigraph-core --test write_lock_perf -- --ignored'
cargo test -p infigraph-core --test write_lock_perf -- --ignored

echo '+cargo test -p infigraph-mcp --test groups_watch_perf -- --ignored'
cargo test -p infigraph-mcp --test groups_watch_perf -- --ignored
